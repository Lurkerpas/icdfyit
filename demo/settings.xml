<?xml version="1.0" encoding="utf-8"?>
<Settings xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
  <UndoDepth>64</UndoDepth>
  <UiScale>1</UiScale>
  <TemplateSets>

    <TemplateSetConfig Name="icd-md">
      <Description>ICD Markdown tables template set.</Description>
      <Templates>
        <Template Name="icd-markdown">
          <Description>Markdown ICD with packet tables</Description>
          <FilePath>../templates/icd/md-tables.mako</FilePath>
          <OutputNamePattern>icd.md</OutputNamePattern>
        </Template>
      </Templates>
    </TemplateSetConfig>

    <TemplateSetConfig Name="asn1">
      <Description>ASN.1 and ACN encoding template set.</Description>
      <Templates>
        <Template Name="asn1-module">
          <Description>ASN.1 module with data types and packet SEQUENCEs</Description>
          <FilePath>../templates/asn1/asn1.mako</FilePath>
          <OutputNamePattern>icd.asn</OutputNamePattern>
        </Template>
        <Template Name="acn-module">
          <Description>ACN encoding companion file</Description>
          <FilePath>../templates/asn1/acn.mako</FilePath>
          <OutputNamePattern>icd.acn</OutputNamePattern>
        </Template>
      </Templates>
    </TemplateSetConfig>

    <TemplateSetConfig Name="c-transcoders">
      <Description>C transcoder template set (utility + generated transcoders).</Description>
      <Templates>
        <Template Name="utility-header">
          <Description>Static utility transcoder header</Description>
          <FilePath>../templates/c-transcoders/icdfyit-transcoders.h</FilePath>
          <OutputNamePattern>icdfyit-transcoders.h</OutputNamePattern>
        </Template>
        <Template Name="utility-source">
          <Description>Static utility transcoder source</Description>
          <FilePath>../templates/c-transcoders/icdfyit-transcoders.c</FilePath>
          <OutputNamePattern>icdfyit-transcoders.c</OutputNamePattern>
        </Template>
        <Template Name="model-header">
          <Description>Model-specific transcoder header</Description>
          <FilePath>../templates/c-transcoders/transcoders.h.mako</FilePath>
          <OutputNamePattern>transcoders.h</OutputNamePattern>
        </Template>
        <Template Name="model-source">
          <Description>Model-specific transcoder source</Description>
          <FilePath>../templates/c-transcoders/transcoders.c.mako</FilePath>
          <OutputNamePattern>transcoders.c</OutputNamePattern>
        </Template>
      </Templates>
    </TemplateSetConfig>

  </TemplateSets>
  <RecentFiles />
</Settings>
