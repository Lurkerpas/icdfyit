<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:IcdFyIt.App.ViewModels"
        xmlns:ctrl="using:IcdFyIt.App.Controls"
        x:Class="IcdFyIt.App.Views.OptionsWindow"
        Icon="avares://IcdFyIt.App/Assets/icon.png"
        Title="Options"
        Width="760" Height="540"
        MinWidth="600" MinHeight="420">

    <LayoutTransformControl>
        <LayoutTransformControl.LayoutTransform>
            <ScaleTransform ScaleX="{DynamicResource AppScale}" ScaleY="{DynamicResource AppScale}" />
        </LayoutTransformControl.LayoutTransform>
    <DockPanel Margin="12">
        <!-- Save / Cancel buttons -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Spacing="8" Margin="0,12,0,0">
            <Button Content="Save"   Command="{Binding SaveCommand}" />
            <Button Content="Cancel" Command="{Binding CancelCommand}" />
        </StackPanel>

        <!-- Tabs: General | Template Sets -->
        <TabControl>

            <!-- ─ General ────────────────────────────────────────────────── -->
            <TabItem Header="General">
                <Grid RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="110,*"
                      Margin="8" RowSpacing="8" ColumnSpacing="8">

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Undo depth:"
                               VerticalAlignment="Center"
                               ToolTip.Tip="Maximum number of undo steps retained in memory. Default: 64." />
                    <NumericUpDown Grid.Row="0" Grid.Column="1"
                                   Value="{Binding UndoDepth}" Minimum="1" Maximum="1000" />

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Python path:"
                               VerticalAlignment="Center"
                               ToolTip.Tip="Absolute path to the Python interpreter used for export. Leave blank to use the system PATH." />
                    <TextBox Grid.Row="1" Grid.Column="1"
                             Text="{Binding PythonPath}"
                             PlaceholderText="(leave blank to use PATH)" />

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="UI Scale:"
                               VerticalAlignment="Center"
                               ToolTip.Tip="Controls the size of all UI elements. Takes effect on Save." />
                    <ComboBox Grid.Row="2" Grid.Column="1"
                              SelectedIndex="{Binding UiScaleIndex}">
                        <ComboBoxItem Content="Small (1×)" />
                        <ComboBoxItem Content="Medium (1.5×)" />
                        <ComboBoxItem Content="Large (2×)" />
                        <ComboBoxItem Content="Very Large (3×)" />
                    </ComboBox>
                </Grid>
            </TabItem>

            <!-- ─ Template Sets ───────────────────────────────────────────── -->
            <TabItem Header="Template Sets">
                <Grid ColumnDefinitions="200,4,*" Margin="4">

                    <!-- Left: Template-set list -->
                    <DockPanel Grid.Column="0">
                        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                                    Spacing="4" Margin="0,4,0,0">
                            <Button Content="Add"
                                    Command="{Binding AddTemplateSetCommand}" />
                            <Button Content="Remove"
                                    Command="{Binding RemoveTemplateSetCommand}" />
                        </StackPanel>

                        <ListBox ItemsSource="{Binding TemplateSets}"
                                 SelectedItem="{Binding SelectedTemplateSet}"
                                 Background="#252526">
                            <ListBox.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:TemplateSetRowViewModel}">
                                    <TextBlock Text="{Binding Name}" Padding="2" />
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </DockPanel>

                    <!-- Splitter -->
                    <GridSplitter Grid.Column="1"
                                  ResizeDirection="Columns"
                                  Background="#555"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Stretch" />

                    <!-- Right: detail panel -->
                    <Grid Grid.Column="2">

                        <!-- Empty state -->
                        <TextBlock Text="← Select a template set to view or edit it."
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Foreground="#858585"
                                   IsVisible="{Binding SelectedTemplateSet,
                                       Converter={x:Static ObjectConverters.IsNull}}" />

                        <!-- Detail panel -->
                        <Grid IsVisible="{Binding SelectedTemplateSet,
                                  Converter={x:Static ObjectConverters.IsNotNull}}"
                              RowDefinitions="Auto,*">

                            <!-- Row 0: metadata + section header -->
                            <ScrollViewer Grid.Row="0" HorizontalScrollBarVisibility="Disabled">
                            <StackPanel Margin="10" Spacing="8">

                                <!-- Template Set metadata -->
                                <TextBlock Text="Template Set"
                                           FontSize="13" FontWeight="SemiBold"
                                           Foreground="#CCCCCC" />

                                <Grid ColumnDefinitions="90,*"
                                      RowDefinitions="Auto,Auto"
                                      RowSpacing="6">
                                    <TextBlock Grid.Row="0" Grid.Column="0"
                                               Text="Name:"
                                               VerticalAlignment="Center" />
                                    <TextBox   Grid.Row="0" Grid.Column="1"
                                               Text="{Binding SelectedTemplateSet.Name}" />

                                    <TextBlock Grid.Row="1" Grid.Column="0"
                                               Text="Description:"
                                               VerticalAlignment="Center" />
                                    <TextBox   Grid.Row="1" Grid.Column="1"
                                               Text="{Binding SelectedTemplateSet.Description}" />
                                </Grid>

                                <Separator Margin="0,4" />

                                <!-- Templates section header -->
                                <DockPanel>
                                    <StackPanel DockPanel.Dock="Right"
                                                Orientation="Horizontal" Spacing="4">
                                        <Button Content="+ Add"
                                                Command="{Binding AddTemplateCommand}" />
                                        <Button Content="Remove"
                                                Command="{Binding RemoveTemplateCommand}" />
                                    </StackPanel>
                                    <TextBlock Text="{Binding TemplateSectionTitle}"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center" />
                                </DockPanel>

                            </StackPanel>
                            </ScrollViewer>

                            <!-- Row 1: templates DraggableGrid (fills remaining height) -->
                            <ctrl:DraggableGrid Grid.Row="1" x:Name="TemplatesGrid"
                                                Margin="10,0,10,8"
                                                ItemsSource="{Binding Templates}"
                                                SelectedItem="{Binding SelectedTemplate, Mode=TwoWay}">
                                <ctrl:DraggableGrid.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="Add"    Command="{Binding AddTemplateCommand}"/>
                                        <MenuItem Header="Remove" Command="{Binding RemoveTemplateCommand}"/>
                                    </ContextMenu>
                                </ctrl:DraggableGrid.ContextMenu>
                                <ctrl:DraggableGrid.Columns>
                                    <ctrl:DraggableGridColumn ColumnType="DragHandle" Width="24"/>
                                    <ctrl:DraggableGridColumn Header="Name"
                                                              Path="Name"
                                                              Width="110"
                                                              IsEditable="True"/>
                                    <ctrl:DraggableGridColumn Header="Description"
                                                              Path="Description"
                                                              Width="110"
                                                              IsEditable="True"/>
                                    <ctrl:DraggableGridColumn Header="Template File"
                                                              Path="FilePath"
                                                              Width="200"
                                                              IsEditable="True"/>
                                    <ctrl:DraggableGridColumn Header=""
                                                              Width="30"
                                                              Name="Browse"/>
                                    <ctrl:DraggableGridColumn Header="Output Name Pattern"
                                                              Path="OutputNamePattern"
                                                              Width="140"
                                                              IsEditable="True"/>
                                </ctrl:DraggableGrid.Columns>
                            </ctrl:DraggableGrid>

                        </Grid>
                    </Grid>

                </Grid>
            </TabItem>

        </TabControl>
    </DockPanel>
    </LayoutTransformControl>
</Window>
