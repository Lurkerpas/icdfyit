<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:IcdFyIt.App.ViewModels"
        x:Class="IcdFyIt.App.Views.OptionsWindow"
        Title="Options"
        Width="640" Height="480"
        MinWidth="500" MinHeight="380">

    <DockPanel Margin="12">
        <!-- Action buttons -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Spacing="8" Margin="0,12,0,0">
            <Button Content="Save"   Command="{Binding SaveCommand}" />
            <Button Content="Cancel" Command="{Binding CancelCommand}" />
        </StackPanel>

        <!-- Tabs: General | Template Sets -->
        <TabControl>
            <TabItem Header="General">
                <Grid RowDefinitions="Auto,Auto,Auto,Auto" ColumnDefinitions="Auto,*"
                      Margin="8" RowSpacing="8" ColumnSpacing="8">
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Undo depth:" VerticalAlignment="Center" />
                    <NumericUpDown Grid.Row="0" Grid.Column="1"
                                   Value="{Binding UndoDepth}" Minimum="1" Maximum="1000" />

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Python path:" VerticalAlignment="Center" />
                    <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding PythonPath}"
                             PlaceholderText="(leave blank to use PATH)" />
                </Grid>
            </TabItem>

            <TabItem Header="Template Sets">
                <!-- Template sets management (ICD-IF-73) -->
                <DockPanel Margin="8">
                    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                                Spacing="4" Margin="0,4,0,0">
                        <Button Content="Add…"    Command="{Binding AddTemplateSetCommand}" />
                        <Button Content="Remove"  Command="{Binding RemoveTemplateSetCommand}" />
                    </StackPanel>
                    <ListBox />
                </DockPanel>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
