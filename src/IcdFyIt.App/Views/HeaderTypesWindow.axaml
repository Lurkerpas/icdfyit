<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:IcdFyIt.App.ViewModels"
        x:Class="IcdFyIt.App.Views.HeaderTypesWindow"
        Title="Header Types"
        Width="950" Height="620"
        MinWidth="600" MinHeight="400">

    <LayoutTransformControl>
        <LayoutTransformControl.LayoutTransform>
            <ScaleTransform ScaleX="{DynamicResource AppScale}" ScaleY="{DynamicResource AppScale}" />
        </LayoutTransformControl.LayoutTransform>
    <DockPanel>

        <!-- ── Toolbar ────────────────────────────────────────────────────── -->
        <Border DockPanel.Dock="Top" Background="#2D2D30" Padding="0,1">
            <DockPanel LastChildFill="False">

                <Menu DockPanel.Dock="Left" Background="Transparent" VerticalAlignment="Center">
                    <MenuItem Header="Edit">
                        <MenuItem Header="Add"       Command="{Binding AddCommand}"/>
                        <MenuItem Header="Duplicate" Command="{Binding DuplicateCommand}"/>
                        <MenuItem Header="Remove"    Command="{Binding RemoveCommand}"/>
                    </MenuItem>
                </Menu>

                <Separator DockPanel.Dock="Left" Margin="4,4" Width="1" Background="#555"/>

                <TextBlock DockPanel.Dock="Left" Text="Filter:" VerticalAlignment="Center"
                           Foreground="#CCCCCC" Margin="6,0,4,0"/>
                <TextBox   DockPanel.Dock="Left"
                           Text="{Binding FilterText, Mode=TwoWay}"
                           PlaceholderText="Search by name or description…"
                           Width="220" Margin="0,2,8,2" VerticalAlignment="Center"/>

            </DockPanel>
        </Border>

        <!-- ── Split: Header Types (top) + ID entries (bottom) ───────────── -->
        <Grid RowDefinitions="*,4,*">

            <!-- Header Types grid -->
            <DataGrid Grid.Row="0"
                      x:Name="HeaderTypesGrid"
                      ItemsSource="{Binding FilteredRows}"
                      SelectedItem="{Binding SelectedRow, Mode=TwoWay}"
                      AutoGenerateColumns="False"
                      CanUserSortColumns="True"
                      CanUserResizeColumns="True"
                      IsReadOnly="False"
                      CellEditEnded="OnHeaderTypeCellEditEnded">

                <DataGrid.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Add"       Command="{Binding AddCommand}"/>
                        <MenuItem Header="Duplicate" Command="{Binding DuplicateCommand}"/>
                        <MenuItem Header="Remove"    Command="{Binding RemoveCommand}"/>
                    </ContextMenu>
                </DataGrid.ContextMenu>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="Name"
                                        Binding="{Binding Name, Mode=TwoWay}"
                                        Width="200"/>
                    <DataGridTextColumn Header="Description"
                                        Binding="{Binding Description, Mode=TwoWay}"
                                        Width="*"/>
                    <DataGridTextColumn Header="IDs"
                                        Binding="{Binding IdCount}"
                                        Width="60" IsReadOnly="True"/>
                </DataGrid.Columns>
            </DataGrid>

            <!-- Splitter -->
            <GridSplitter Grid.Row="1"
                          ResizeDirection="Rows"
                          HorizontalAlignment="Stretch"
                          Background="#3F3F46"/>

            <!-- ID entries panel -->
            <DockPanel Grid.Row="2">

                <!-- IDs section toolbar -->
                <Border DockPanel.Dock="Top" Background="#3F3F46" Padding="4,2">
                    <DockPanel LastChildFill="False">
                        <TextBlock DockPanel.Dock="Left"
                                   Text="{Binding IdSectionTitle}"
                                   Foreground="#CCCCCC" FontWeight="SemiBold"
                                   VerticalAlignment="Center" Margin="4,0,12,0"/>
                        <Menu DockPanel.Dock="Right" Background="Transparent" VerticalAlignment="Center">
                            <MenuItem Header="Edit">
                                <MenuItem Header="Add ID"       Command="{Binding AddIdCommand}"/>
                                <MenuItem Header="Remove ID"    Command="{Binding RemoveIdCommand}"/>
                                <Separator/>
                                <MenuItem Header="Set Data Type…" Command="{Binding EditIdDataTypeCommand}"/>
                            </MenuItem>
                        </Menu>
                    </DockPanel>
                </Border>

                <!-- ID entries grid -->
                <DataGrid x:Name="IdsGrid"
                          ItemsSource="{Binding IdRows}"
                          SelectedItem="{Binding SelectedIdRow, Mode=TwoWay}"
                          AutoGenerateColumns="False"
                          CanUserSortColumns="True"
                          CanUserResizeColumns="True"
                          IsReadOnly="False"
                          CellEditEnded="OnIdCellEditEnded">

                    <DataGrid.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="Add ID"         Command="{Binding AddIdCommand}"/>
                            <MenuItem Header="Remove ID"      Command="{Binding RemoveIdCommand}"/>
                            <Separator/>
                            <MenuItem Header="Set Data Type…" Command="{Binding EditIdDataTypeCommand}"/>
                        </ContextMenu>
                    </DataGrid.ContextMenu>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Name"
                                            Binding="{Binding Name, Mode=TwoWay}"
                                            Width="180"/>
                        <DataGridTextColumn Header="Description"
                                            Binding="{Binding Description, Mode=TwoWay}"
                                            Width="*"/>
                        <DataGridTextColumn Header="Data Type"
                                            Binding="{Binding DataTypeName}"
                                            Width="180" IsReadOnly="True"/>
                    </DataGrid.Columns>
                </DataGrid>

            </DockPanel>

        </Grid>

    </DockPanel>
    </LayoutTransformControl>
</Window>
