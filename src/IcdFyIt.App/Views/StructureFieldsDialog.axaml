<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="IcdFyIt.App.Views.StructureFieldsDialog"
        Title="{Binding TypeName, StringFormat='Structure Fields – {0}'}"
        Width="560" Height="420"
        MinWidth="360" MinHeight="260"
        WindowStartupLocation="CenterOwner">

    <DockPanel Margin="8">

        <!-- Add + Close -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Spacing="4" Margin="0,6,0,0">
            <Button Content="Add" Command="{Binding AddCommand}"/>
            <Button Content="Close" IsDefault="True" Click="OnCloseClicked"/>
        </StackPanel>

        <!-- Column headers -->
        <Border DockPanel.Dock="Top" Background="#2D2D30" Padding="4,3" Margin="0,0,0,2">
            <Grid ColumnDefinitions="*,2*,28">
                <TextBlock Grid.Column="0" Text="Name"      Foreground="#CCCCCC" FontWeight="SemiBold"/>
                <TextBlock Grid.Column="1" Text="Data Type" Foreground="#CCCCCC" FontWeight="SemiBold"/>
            </Grid>
        </Border>

        <!-- Field rows — ItemsControl avoids DataGrid popup-crash on Linux/X11 -->
        <ScrollViewer>
            <ItemsControl ItemsSource="{Binding Fields}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid ColumnDefinitions="*,2*,28" Margin="0,1">
                            <TextBox Grid.Column="0"
                                     Text="{Binding Name, Mode=TwoWay}"
                                     Margin="0,0,2,0"/>
                            <AutoCompleteBox Grid.Column="1"
                                             ItemsSource="{Binding AvailableTypes}"
                                             SelectedItem="{Binding DataType, Mode=TwoWay}"
                                             FilterMode="Contains"
                                             MinimumPrefixLength="0"
                                             Margin="0,0,2,0"/>
                            <Button Grid.Column="2"
                                    Content="✕" Width="26" Height="26" Padding="0"
                                    Command="{Binding RemoveCommand}"
                                    VerticalAlignment="Center" HorizontalAlignment="Center"
                                    ToolTip.Tip="Remove field"/>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

    </DockPanel>
</Window>
