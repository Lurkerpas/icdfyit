<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:IcdFyIt.App.ViewModels"
        x:Class="IcdFyIt.App.Views.ValidationDialog"
        Icon="avares://IcdFyIt.App/Assets/icon.png"
        Title="Validation Results"
        SizeToContent="WidthAndHeight"
        MinWidth="400" MinHeight="250"
        MaxHeight="600">

    <LayoutTransformControl>
        <LayoutTransformControl.LayoutTransform>
            <ScaleTransform ScaleX="{DynamicResource AppScale}" ScaleY="{DynamicResource AppScale}" />
        </LayoutTransformControl.LayoutTransform>
    <DockPanel Margin="8">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Spacing="8" Margin="0,8,0,0">
            <Button Content="Copy to Clipboard" Click="OnCopyToClipboardClicked" />
            <Button Content="Close" Click="OnCloseClicked" />
        </StackPanel>

        <ListBox ItemsSource="{Binding Issues}"
                 SelectionMode="Multiple">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding Message}" TextWrapping="Wrap" />
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </DockPanel>
    </LayoutTransformControl>
</Window>
