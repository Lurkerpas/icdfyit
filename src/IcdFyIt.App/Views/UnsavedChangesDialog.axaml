<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="IcdFyIt.App.Views.UnsavedChangesDialog"
        Icon="avares://IcdFyIt.App/Assets/icon.png"
        Title="Unsaved Changes"
        SizeToContent="WidthAndHeight"
        MinWidth="390" MinHeight="160"
        CanResize="False"
        WindowStartupLocation="CenterOwner">

    <LayoutTransformControl>
        <LayoutTransformControl.LayoutTransform>
            <ScaleTransform ScaleX="{DynamicResource AppScale}" ScaleY="{DynamicResource AppScale}" />
        </LayoutTransformControl.LayoutTransform>
    <StackPanel Margin="20" Spacing="16">
        <TextBlock Text="You have unsaved changes. What would you like to do?"
                   TextWrapping="Wrap" />

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
            <Button Content="_Save"    IsDefault="True"  Click="OnSaveClicked"    />
            <Button Content="_Discard"                   Click="OnDiscardClicked" />
            <Button Content="Cancel"   IsCancel="True"   Click="OnCancelClicked"  />
        </StackPanel>
    </StackPanel>
    </LayoutTransformControl>
</Window>
