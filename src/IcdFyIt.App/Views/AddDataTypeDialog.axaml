<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="IcdFyIt.App.Views.AddDataTypeDialog"
        Title="Add Data Type"
        SizeToContent="WidthAndHeight"
        MinWidth="300"
        CanResize="False"
        WindowStartupLocation="CenterOwner">

    <LayoutTransformControl>
        <LayoutTransformControl.LayoutTransform>
            <ScaleTransform ScaleX="{DynamicResource AppScale}" ScaleY="{DynamicResource AppScale}" />
        </LayoutTransformControl.LayoutTransform>
    <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto" Margin="16" RowSpacing="6">
        <TextBlock Grid.Row="0" Text="Name:" />
        <TextBox  Grid.Row="1" x:Name="NameBox"
                  Text="{Binding Name}"
                  PlaceholderText="e.g. MyUInt16" />

        <TextBlock Grid.Row="2" Text="Kind:" Margin="0,6,0,0" />
        <ComboBox  Grid.Row="3" x:Name="KindBox"
                   ItemsSource="{Binding AllKinds}"
                   SelectedItem="{Binding SelectedKind}"
                   HorizontalAlignment="Stretch" />

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right"
                    Spacing="8" Margin="0,12,0,0">
            <Button Content="OK"
                    IsDefault="True"
                    IsEnabled="{Binding IsValid}"
                    Click="OnOkClicked" />
            <Button Content="Cancel"
                    IsCancel="True"
                    Click="OnCancelClicked" />
        </StackPanel>
    </Grid>
    </LayoutTransformControl>
</Window>
