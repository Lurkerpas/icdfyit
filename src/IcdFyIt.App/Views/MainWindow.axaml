<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:IcdFyIt.App.ViewModels"
        xmlns:conv="using:Avalonia.Data.Converters"
        xmlns:ctrl="using:IcdFyIt.App.Controls"
        x:Class="IcdFyIt.App.Views.MainWindow"
        Icon="avares://IcdFyIt.App/Assets/icon.png"
        Title="{Binding Title}"
        Width="1024" Height="768"
        MinWidth="800" MinHeight="600"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaTitleBarHeightHint="-1">

    <DockPanel>
        <!-- Menu bar (ICD-IF-10 to ICD-IF-52) -->
        <!-- FontSize is inherited by popup/submenu items, scaling them with AppMenuFontSize -->
        <Menu DockPanel.Dock="Top" FontSize="{DynamicResource AppMenuFontSize}">
            <MenuItem Header="_File">
                <MenuItem Header="_New"      Command="{Binding NewDocumentCommand}" />
                <MenuItem Header="_Open…"    Command="{Binding OpenDocumentCommand}" />
                <MenuItem Header="Re_open"   ItemsSource="{Binding RecentFiles}">
                    <MenuItem.ItemContainerTheme>
                        <ControlTheme TargetType="MenuItem"
                                      BasedOn="{StaticResource {x:Type MenuItem}}">
                            <Setter Property="Header"       Value="{Binding Header}" />
                            <Setter Property="Command"      Value="{Binding OpenCommand}" />
                            <Setter Property="ToolTip.Tip"  Value="{Binding FullPath}" />
                        </ControlTheme>
                    </MenuItem.ItemContainerTheme>
                </MenuItem>
                <Separator />
                <MenuItem Header="_Save"     Command="{Binding SaveDocumentCommand}" />
                <MenuItem Header="Save _As…" Command="{Binding SaveDocumentAsCommand}" />
                <Separator />
                <MenuItem Header="E_xit"     Command="{Binding ExitCommand}" />
            </MenuItem>
            <MenuItem Header="_Edit">
                <MenuItem Header="_Undo"     Command="{Binding UndoCommand}" />
                <MenuItem Header="_Redo"     Command="{Binding RedoCommand}" />
                <Separator />
                <MenuItem Header="Add _Telecommand…" Command="{Binding AddTelecommandCommand}" />
                <MenuItem Header="Add T_elemetry…"   Command="{Binding AddTelemetryCommand}" />
                <MenuItem Header="_Duplicate"         Command="{Binding DuplicatePacketTypeCommand}" />
                <MenuItem Header="Remo_ve"            Command="{Binding RemovePacketTypeCommand}" />
                <Separator />
                <MenuItem Header="Add _Field"        Command="{Binding AddFieldCommand}" />
                <Separator />
                <MenuItem Header="_Validate…"        Command="{Binding RunValidationCommand}" />
            </MenuItem>
            <MenuItem Header="_View">
                <MenuItem Header="_Data Types…"   Command="{Binding OpenDataTypesCommand}" />
                <MenuItem Header="_Parameters…"   Command="{Binding OpenParametersCommand}" />
                <MenuItem Header="_Header Types…" Command="{Binding OpenHeaderTypesCommand}" />
                <MenuItem Header="_Memories…"     Command="{Binding OpenMemoriesCommand}" />
                <MenuItem Header="M_etadata…"     Command="{Binding OpenMetadataCommand}" />
                <Separator />
                <MenuItem Header="_Appearance">
                    <MenuItem Header="_Increase Size" Command="{Binding IncreaseSizeCommand}" />
                    <MenuItem Header="_Decrease Size" Command="{Binding DecreaseSizeCommand}" />
                    <Separator />
                    <MenuItem Header="_Sizes">
                        <MenuItem Header="_Small"     Command="{Binding SetSizeSmallCommand}" />
                        <MenuItem Header="_Medium"    Command="{Binding SetSizeMediumCommand}" />
                        <MenuItem Header="_Large"     Command="{Binding SetSizeLargeCommand}" />
                        <MenuItem Header="_Very Large" Command="{Binding SetSizeVeryLargeCommand}" />
                    </MenuItem>
                    <Separator />
                    <MenuItem Header="_Reset Sizes to Default" Click="OnResetSizesToDefaultClicked" />
                </MenuItem>
            </MenuItem>
            <MenuItem Header="_Tools">
                <MenuItem Header="_Export…"       Command="{Binding OpenExportWindowCommand}" />
                <Separator />
                <MenuItem Header="_Options…" Command="{Binding OpenOptionsCommand}" />
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="_About"      Command="{Binding OpenAboutCommand}" />
                <MenuItem Header="Open _Help"  Command="{Binding OpenHelpCommand}" />
            </MenuItem>
        </Menu>

        <!-- Scaled content area: status bar + main content scale together -->
        <LayoutTransformControl>
            <LayoutTransformControl.LayoutTransform>
                <ScaleTransform ScaleX="{DynamicResource AppScale}" ScaleY="{DynamicResource AppScale}" />
            </LayoutTransformControl.LayoutTransform>
            <DockPanel>
        <!-- Status bar -->
        <Border DockPanel.Dock="Bottom" Background="#2D2D30" Padding="6,2">
            <TextBlock Text="Ready" Foreground="#CCCCCC" FontSize="11" />
        </Border>

        <!-- Main content: tree | splitter | detail -->
        <Grid ColumnDefinitions="220,4,*">

            <!-- ── Left: packet-type lists (ICD-IF-60, ICD-IF-61) ──────────── -->
            <Grid Grid.Column="0" x:Name="PacketListsGrid" RowDefinitions="*,4,*">

                <!-- Telecommands section -->
                <DockPanel Grid.Row="0">
                    <Border DockPanel.Dock="Top" Background="#3F3F46" Padding="0,2">
                        <DockPanel LastChildFill="True">
                            <Button DockPanel.Dock="Left"  x:Name="TcToggleButton"
                                    Content="▼" Width="22" Padding="0" Margin="2,0,0,0"
                                    HorizontalContentAlignment="Center"
                                    VerticalContentAlignment="Center"
                                    Background="Transparent" BorderThickness="0"
                                    Foreground="#CCCCCC" FontSize="10"
                                    ToolTip.Tip="Collapse / expand"
                                    Click="OnTcToggle" />
                            <Button DockPanel.Dock="Right" Content="TC+" Margin="2"
                                    Command="{Binding AddTelecommandCommand}"
                                    ToolTip.Tip="Add Telecommand" />
                            <TextBlock Text="Telecommands" Padding="6,2"
                                       VerticalAlignment="Center"
                                       Foreground="#CCCCCC" FontWeight="SemiBold" />
                        </DockPanel>
                    </Border>
                    <ctrl:DraggableGrid x:Name="TelecommandsGrid"
                                        ItemsSource="{Binding Telecommands}"
                                        SelectedItem="{Binding SelectedPacketType, Mode=TwoWay}"
                                        ShowHeader="False">
                        <ctrl:DraggableGrid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Add Telecommand…"
                                          Command="{Binding AddTelecommandCommand}" />
                                <MenuItem Header="Duplicate"
                                          Command="{Binding DuplicatePacketTypeCommand}" />
                                <Separator />
                                <MenuItem Header="Remove"
                                          Command="{Binding RemovePacketTypeCommand}" />
                            </ContextMenu>
                        </ctrl:DraggableGrid.ContextMenu>
                        <ctrl:DraggableGrid.Columns>
                            <ctrl:DraggableGridColumn ColumnType="DragHandle" Width="24"/>
                            <ctrl:DraggableGridColumn Path="DisplayLabel"/>
                        </ctrl:DraggableGrid.Columns>
                    </ctrl:DraggableGrid>
                </DockPanel>

                <!-- Section splitter -->
                <GridSplitter Grid.Row="1" x:Name="PacketListsSplitter"
                              ResizeDirection="Rows"
                              HorizontalAlignment="Stretch"
                              Background="#3F3F46"/>

                <!-- Telemetries section -->
                <DockPanel Grid.Row="2">
                    <Border DockPanel.Dock="Top" Background="#3F3F46" Padding="0,2">
                        <DockPanel LastChildFill="True">
                            <Button DockPanel.Dock="Left"  x:Name="TmToggleButton"
                                    Content="▼" Width="22" Padding="0" Margin="2,0,0,0"
                                    HorizontalContentAlignment="Center"
                                    VerticalContentAlignment="Center"
                                    Background="Transparent" BorderThickness="0"
                                    Foreground="#CCCCCC" FontSize="10"
                                    ToolTip.Tip="Collapse / expand"
                                    Click="OnTmToggle" />
                            <Button DockPanel.Dock="Right" Content="TM+" Margin="2"
                                    Command="{Binding AddTelemetryCommand}"
                                    ToolTip.Tip="Add Telemetry" />
                            <TextBlock Text="Telemetries" Padding="6,2"
                                       VerticalAlignment="Center"
                                       Foreground="#CCCCCC" FontWeight="SemiBold" />
                        </DockPanel>
                    </Border>
                    <ctrl:DraggableGrid x:Name="TelemetriesGrid"
                                        ItemsSource="{Binding Telemetries}"
                                        SelectedItem="{Binding SelectedPacketType, Mode=TwoWay}"
                                        ShowHeader="False">
                        <ctrl:DraggableGrid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Add Telemetry…"
                                          Command="{Binding AddTelemetryCommand}" />
                                <MenuItem Header="Duplicate"
                                          Command="{Binding DuplicatePacketTypeCommand}" />
                                <Separator />
                                <MenuItem Header="Remove"
                                          Command="{Binding RemovePacketTypeCommand}" />
                            </ContextMenu>
                        </ctrl:DraggableGrid.ContextMenu>
                        <ctrl:DraggableGrid.Columns>
                            <ctrl:DraggableGridColumn ColumnType="DragHandle" Width="24"/>
                            <ctrl:DraggableGridColumn Path="DisplayLabel"/>
                        </ctrl:DraggableGrid.Columns>
                    </ctrl:DraggableGrid>
                </DockPanel>

            </Grid>

            <!-- Splitter -->
            <GridSplitter Grid.Column="1"
                          ResizeDirection="Columns"
                          Background="#555"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch" />

            <!-- ── Right: detail panel ─────────────────────────────────────── -->
            <Grid Grid.Column="2">

                <!-- Empty state -->
                <TextBlock Text="← Select a packet type to view its details."
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Foreground="#858585"
                           IsVisible="{Binding SelectedPacketType,
                               Converter={x:Static ObjectConverters.IsNull}}" />

                <!-- Detail content  (shown when a packet type is selected) -->
                <Grid IsVisible="{Binding SelectedPacketType,
                          Converter={x:Static ObjectConverters.IsNotNull}}"
                      RowDefinitions="Auto,*">

                    <!-- Row 0: scrollable metadata and fields label -->
                    <ScrollViewer Grid.Row="0" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="14" Spacing="8">

                        <!-- ─ Metadata ────────────────────────────────────── -->
                        <TextBlock Text="Packet Type"
                                   FontSize="13" FontWeight="SemiBold"
                                   Foreground="#CCCCCC" />

                        <Grid ColumnDefinitions="90,*"
                              RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto"
                              RowSpacing="6">

                            <TextBlock Grid.Row="0" Grid.Column="0"
                                       Text="Name:" VerticalAlignment="Center" />
                            <TextBox   Grid.Row="0" Grid.Column="1"
                                       Text="{Binding SelectedPacketType.Name}" />

                            <TextBlock Grid.Row="1" Grid.Column="0"
                                       Text="Description:" VerticalAlignment="Top"
                                       Margin="0,4,0,0" />
                            <TextBox   Grid.Row="1" Grid.Column="1"
                                       Text="{Binding SelectedPacketType.Description}"
                                       AcceptsReturn="True" MinHeight="54"
                                       TextWrapping="Wrap" />

                            <TextBlock Grid.Row="2" Grid.Column="0"
                                       Text="ID:" VerticalAlignment="Center" />
                            <TextBox   Grid.Row="2" Grid.Column="1"
                                       Text="{Binding SelectedPacketType.NumericId}" />

                            <TextBlock Grid.Row="3" Grid.Column="0"
                                       Text="Mnemonic:" VerticalAlignment="Center" />
                            <TextBox   Grid.Row="3" Grid.Column="1"
                                       Text="{Binding SelectedPacketType.Mnemonic}" />

                            <TextBlock Grid.Row="4" Grid.Column="0"
                                       Text="Kind:" VerticalAlignment="Center" />
                            <TextBlock Grid.Row="4" Grid.Column="1"
                                       Text="{Binding SelectedPacketType.Kind}"
                                       VerticalAlignment="Center" />

                            <TextBlock Grid.Row="5" Grid.Column="0"
                                       Text="Header Type:" VerticalAlignment="Center" />
                            <DockPanel Grid.Row="5" Grid.Column="1">
                                <Button DockPanel.Dock="Right" Content="…" Margin="4,0,0,0"
                                        Command="{Binding SelectHeaderTypeCommand}"
                                        ToolTip.Tip="Select Header Type" />
                                <TextBlock Text="{Binding SelectedPacketType.HeaderTypeName}"
                                           VerticalAlignment="Center" />
                            </DockPanel>
                        </Grid>

                        <!-- ─ Header ID Values (visible when a Header Type is assigned) ─ -->
                        <StackPanel IsVisible="{Binding SelectedPacketType.HasHeaderType}"
                                    Spacing="4">
                            <Separator Margin="0,4" />

                            <TextBlock Text="Header ID Values"
                                       FontWeight="SemiBold" Foreground="#CCCCCC" />

                            <!-- Column headers -->
                            <Grid ColumnDefinitions="150,*" Margin="0,2,0,0">
                                <TextBlock Grid.Column="0" Text="ID Name"
                                           Foreground="#858585" FontSize="11" />
                                <TextBlock Grid.Column="1" Text="Fixed Value"
                                           Foreground="#858585" FontSize="11" Margin="4,0,0,0" />
                            </Grid>

                            <!-- Header ID value rows -->
                            <ItemsControl ItemsSource="{Binding SelectedPacketType.HeaderIdValueRows}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type vm:HeaderIdValueRowViewModel}">
                                        <Grid ColumnDefinitions="150,*" Margin="0,1">
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding IdName}"
                                                       VerticalAlignment="Center"
                                                       Padding="3,2" />
                                            <TextBox Grid.Column="1"
                                                     Text="{Binding Value}"
                                                     BorderThickness="0,0,0,1"
                                                     Padding="3,2" Margin="2,0,0,0" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <Separator Margin="0,4" />

                        <!-- ─ Fields ──────────────────────────────────────── -->
                        <DockPanel>
                            <Button DockPanel.Dock="Right"
                                    Content="+ Add Field"
                                    Command="{Binding AddFieldCommand}" />
                            <TextBlock Text="Fields"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center" />
                        </DockPanel>

                    </StackPanel>
                    </ScrollViewer>

                    <!-- Row 1: fields DraggableGrid (fills remaining height) -->
                    <ctrl:DraggableGrid Grid.Row="1" x:Name="FieldsGrid"
                                        Margin="14,0,14,8"
                                        ItemsSource="{Binding SelectedPacketType.Fields}"
                                        SelectedItem="{Binding SelectedField, Mode=TwoWay}">
                        <ctrl:DraggableGrid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Add Field" Command="{Binding AddFieldCommand}"/>
                                <MenuItem Header="Remove"    Command="{Binding RemoveFieldCommand}"/>
                            </ContextMenu>
                        </ctrl:DraggableGrid.ContextMenu>
                        <ctrl:DraggableGrid.Columns>
                            <ctrl:DraggableGridColumn ColumnType="DragHandle" Width="24"/>
                            <ctrl:DraggableGridColumn Header="Name"
                                                      Path="Name"
                                                      Width="110"
                                                      IsEditable="True"/>
                            <ctrl:DraggableGridColumn Header="Description"
                                                      Path="Description"
                                                      Width="160"
                                                      IsEditable="True"/>
                            <ctrl:DraggableGridColumn Header="Parameter"
                                                      Width="200"
                                                      Name="Parameter"/>
                            <ctrl:DraggableGridColumn Header="Type Ind."
                                                      Width="70"
                                                      Name="IsTypeIndicator"/>
                            <ctrl:DraggableGridColumn Header="Ind. Value"
                                                      Width="90"
                                                      Name="IndicatorValue"/>
                        </ctrl:DraggableGrid.Columns>
                    </ctrl:DraggableGrid>

                </Grid>

            </Grid>
        </Grid>
            </DockPanel>
        </LayoutTransformControl>
    </DockPanel>
</Window>
