<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:IcdFyIt.App.ViewModels"
        x:Class="IcdFyIt.App.Views.ExportWindow"
        Icon="avares://IcdFyIt.App/Assets/icon.png"
        Title="Export"
        Width="560" Height="320"
        MinWidth="450" MinHeight="260">

    <LayoutTransformControl>
        <LayoutTransformControl.LayoutTransform>
            <ScaleTransform ScaleX="{DynamicResource AppScale}" ScaleY="{DynamicResource AppScale}" />
        </LayoutTransformControl.LayoutTransform>
    <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,*" Margin="14">

        <!-- Template Set -->
        <TextBlock Grid.Row="0" Text="Template Set:" Margin="0,0,0,4" />
        <ComboBox Grid.Row="1"
                  ItemsSource="{Binding TemplateSets}"
                  SelectedItem="{Binding SelectedTemplateSet}"
                  DisplayMemberBinding="{Binding Name}"
                  IsEnabled="{Binding IsNotExporting}"
                  HorizontalAlignment="Stretch" Margin="0,0,0,8" />

        <!-- Output folder -->
        <TextBlock Grid.Row="2" Text="Output folder:" Margin="0,0,0,4" />
        <Grid Grid.Row="3" ColumnDefinitions="*,Auto" Margin="0,0,0,8">
            <TextBox Grid.Column="0"
                     Text="{Binding OutputFolder}"
                     IsEnabled="{Binding IsNotExporting}"
                     PlaceholderText="Select or type an output folder path…" />
            <Button Grid.Column="1" Content="…"
                    Command="{Binding BrowseOutputFolderCommand}"
                    IsEnabled="{Binding IsNotExporting}"
                    Margin="4,0,0,0" ToolTip.Tip="Browse for output folder" />
        </Grid>

        <!-- Export button row -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
            <Button Content="Export"
                    Command="{Binding ExportCommand}"
                    IsDefault="True" />
        </StackPanel>

        <!-- Status message -->
        <Border Grid.Row="5"
                IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                Background="#2A2A2A" CornerRadius="3" Padding="8,6" Margin="0,10,0,0"
                VerticalAlignment="Top">
            <TextBlock Text="{Binding StatusMessage}"
                       TextWrapping="Wrap"
                       Foreground="#CCCCCC" />
        </Border>

    </Grid>
    </LayoutTransformControl>
</Window>
