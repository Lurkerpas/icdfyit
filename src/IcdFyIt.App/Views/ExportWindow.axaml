<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:IcdFyIt.App.ViewModels"
        x:Class="IcdFyIt.App.Views.ExportWindow"
        Title="Export"
        Width="600" Height="300"
        MinWidth="450" MinHeight="250"
        CanResize="False">

    <Grid RowDefinitions="Auto,Auto,Auto,*,Auto" Margin="12">
        <TextBlock Grid.Row="0" Text="Template Set:" Margin="0,0,0,4" />
        <ComboBox Grid.Row="1"
                  ItemsSource="{Binding TemplateSets}"
                  SelectedItem="{Binding SelectedTemplateSet}"
                  DisplayMemberBinding="{Binding Name}"
                  HorizontalAlignment="Stretch" Margin="0,0,0,8" />

        <TextBlock Grid.Row="2" Text="Output folder:" Margin="0,0,0,4" />
        <Grid Grid.Row="3" ColumnDefinitions="*,Auto">
            <TextBox Grid.Column="0" Text="{Binding OutputFolder}" />
            <Button Grid.Column="1" Content="Browse…"
                    Command="{Binding BrowseOutputFolderCommand}" Margin="4,0,0,0" />
        </Grid>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right"
                    Spacing="8" Margin="0,12,0,0">
            <Button Content="Export" Command="{Binding ExportCommand}" />
        </StackPanel>
    </Grid>
</Window>
