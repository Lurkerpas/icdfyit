<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:IcdFyIt.App.ViewModels"
        x:Class="IcdFyIt.App.Views.DataTypesWindow"
        Title="Data Types"
        Width="900" Height="600"
        MinWidth="600" MinHeight="400">

    <DockPanel>
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Spacing="4" Margin="4">
            <Button Content="Add"       Command="{Binding AddCommand}" />
            <Button Content="Duplicate" Command="{Binding DuplicateCommand}" />
            <Button Content="Remove"    Command="{Binding RemoveCommand}" />
        </StackPanel>

        <DataGrid ItemsSource="{Binding DataTypes}"
                  SelectedItem="{Binding Selected}"
                  AutoGenerateColumns="False"
                  CanUserSortColumns="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Name"      Binding="{Binding Name}" Width="*" />
                <DataGridTextColumn Header="Base Type" Binding="{Binding Kind}" Width="150" />
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>
