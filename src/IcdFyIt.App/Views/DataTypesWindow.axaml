<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:IcdFyIt.App.ViewModels"
        xmlns:cvt="using:IcdFyIt.App.Converters"
        x:Class="IcdFyIt.App.Views.DataTypesWindow"
        Title="Data Types"
        Width="1100" Height="640"
        MinWidth="700" MinHeight="400">

    <DockPanel>

        <!-- ── Toolbar: integrated menu + filter ──────────────────────────── -->
        <Border DockPanel.Dock="Top" Background="#2D2D30" Padding="0,1">
            <DockPanel LastChildFill="False">

                <!-- Left: action / column / data menus -->
                <Menu DockPanel.Dock="Left" Background="Transparent" VerticalAlignment="Center">

                    <!-- Edit actions -->
                    <MenuItem Header="Edit">
                        <MenuItem Header="Add…"      Command="{Binding AddCommand}"/>
                        <MenuItem Header="Duplicate" Command="{Binding DuplicateCommand}"/>
                        <MenuItem Header="Remove"    Command="{Binding RemoveCommand}"/>
                        <Separator IsVisible="{Binding CanEditValues}"/>
                        <MenuItem Header="Edit Values…" Command="{Binding EditValuesCommand}"
                                  IsVisible="{Binding CanEditValues}"/>
                        <Separator IsVisible="{Binding CanEditFields}"/>
                        <MenuItem Header="Edit Fields…" Command="{Binding EditStructureFieldsCommand}"
                                  IsVisible="{Binding CanEditFields}"/>
                        <Separator IsVisible="{Binding CanEditArray}"/>
                        <MenuItem Header="Edit Array…" Command="{Binding EditArrayCommand}"
                                  IsVisible="{Binding CanEditArray}"/>
                    </MenuItem>

                    <!-- Column visibility toggles -->
                    <MenuItem Header="Columns">
                        <MenuItem Header="Endianness"    x:Name="EndiannessItem"
                                  ToggleType="CheckBox" IsChecked="True"
                                  Click="OnColumnMenuItemChanged"/>
                        <MenuItem Header="Bit Size"      x:Name="BitSizeItem"
                                  ToggleType="CheckBox" IsChecked="True"
                                  Click="OnColumnMenuItemChanged"/>
                        <MenuItem Header="Range Min/Max" x:Name="RangeItem"
                                  ToggleType="CheckBox" IsChecked="True"
                                  Click="OnColumnMenuItemChanged"/>
                        <MenuItem Header="Unit"          x:Name="UnitItem"
                                  ToggleType="CheckBox" IsChecked="True"
                                  Click="OnColumnMenuItemChanged"/>
                        <MenuItem Header="Calibration"   x:Name="CalibrationItem"
                                  ToggleType="CheckBox" IsChecked="True"
                                  Click="OnColumnMenuItemChanged"/>
                        <MenuItem Header="Details"       x:Name="DetailsItem"
                                  ToggleType="CheckBox" IsChecked="True"
                                  Click="OnColumnMenuItemChanged"/>
                    </MenuItem>

                    <!-- CSV import / export -->
                    <MenuItem Header="Data">
                        <MenuItem Header="Export CSV" Command="{Binding ExportCsvCommand}"/>
                        <MenuItem Header="Import CSV" Command="{Binding ImportCsvCommand}"/>
                    </MenuItem>

                </Menu>

                <!-- Separator -->
                <Separator DockPanel.Dock="Left" Margin="4,4" Width="1" Background="#555"/>

                <!-- Filter by name -->
                <TextBlock DockPanel.Dock="Left" Text="Filter:" VerticalAlignment="Center"
                           Foreground="#CCCCCC" Margin="6,0,4,0"/>
                <TextBox   DockPanel.Dock="Left"
                           Text="{Binding FilterText, Mode=TwoWay}"
                           PlaceholderText="Search by name…"
                           Width="180" Margin="0,2,8,2" VerticalAlignment="Center"/>

                <!-- Filter by kind -->
                <TextBlock DockPanel.Dock="Left" Text="Kind:" VerticalAlignment="Center"
                           Foreground="#CCCCCC" Margin="0,0,4,0"/>
                <ComboBox  DockPanel.Dock="Left"
                           ItemsSource="{Binding AllKindFilters}"
                           SelectedItem="{Binding SelectedKindFilter, Mode=TwoWay}"
                           Width="140" VerticalAlignment="Center"/>

            </DockPanel>
        </Border>

        <!-- ── Spreadsheet grid (ICD-IF-120) ─────────────────────────────── -->
        <DataGrid x:Name="TypesGrid"
                  ItemsSource="{Binding FilteredRows}"
                  SelectedItem="{Binding SelectedRow, Mode=TwoWay}"
                  AutoGenerateColumns="False"
                  CanUserSortColumns="True"
                  CanUserResizeColumns="True"
                  IsReadOnly="False"
                  CellEditEnded="OnCellEditEnded"
                  BeginningEdit="OnBeginningEdit">

            <!-- Context menu: Add / Duplicate / Remove + Edit Values for enums -->
            <DataGrid.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Add…"         Command="{Binding AddCommand}"/>
                    <MenuItem Header="Duplicate"    Command="{Binding DuplicateCommand}"/>
                    <MenuItem Header="Remove"       Command="{Binding RemoveCommand}"/>
                    <Separator IsVisible="{Binding CanEditValues}"/>
                    <MenuItem Header="Edit Values…" Command="{Binding EditValuesCommand}"
                              IsVisible="{Binding CanEditValues}"/>
                    <Separator IsVisible="{Binding CanEditFields}"/>
                    <MenuItem Header="Edit Fields…" Command="{Binding EditStructureFieldsCommand}"
                              IsVisible="{Binding CanEditFields}"/>
                    <Separator IsVisible="{Binding CanEditArray}"/>
                    <MenuItem Header="Edit Array…" Command="{Binding EditArrayCommand}"
                              IsVisible="{Binding CanEditArray}"/>
                </ContextMenu>
            </DataGrid.ContextMenu>

            <DataGrid.Columns>

                <!-- Name — all types -->
                <DataGridTextColumn Header="Name"
                                    Binding="{Binding Name, Mode=TwoWay}"
                                    Width="160"/>

                <!-- Kind — all types, read-only -->
                <DataGridTextColumn Header="Kind"
                                    Binding="{Binding Kind}"
                                    Width="130" IsReadOnly="True"/>

                <!-- Endianness — inline RadioButtons; no popup so safe on X11 -->
                <DataGridTemplateColumn Header="Endianness" Width="115" IsReadOnly="True">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                                        IsEnabled="{Binding IsScalarApplicable}"
                                        Opacity="{Binding IsScalarApplicable,
                                                  Converter={x:Static cvt:BoolToOpacityConverter.Instance}}"
                                        Margin="6,0">
                                <RadioButton Content="LE" IsChecked="{Binding IsLittleEndian, Mode=TwoWay}"
                                             Margin="0,0,8,0" ToolTip.Tip="Little endian"/>
                                <RadioButton Content="BE" IsChecked="{Binding IsBigEndian, Mode=TwoWay}"
                                             ToolTip.Tip="Big endian"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Bit Size — scalar types and Enumerated -->
                <DataGridTemplateColumn Header="Bit Size" Width="95">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding BitSize, TargetNullValue='—'}"
                                       Opacity="{Binding IsBitSizeApplicable,
                                                 Converter={x:Static cvt:BoolToOpacityConverter.Instance}}"
                                       Padding="8,2" VerticalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                    <DataGridTemplateColumn.CellEditingTemplate>
                        <DataTemplate>
                            <TextBox Text="{Binding BitSize, Mode=TwoWay}"
                                     HorizontalAlignment="Stretch"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellEditingTemplate>
                </DataGridTemplateColumn>

                <!-- Range Min — numeric types only -->
                <DataGridTemplateColumn Header="Range Min" Width="120">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding RangeMin, TargetNullValue='—'}"
                                       Opacity="{Binding IsNumericApplicable,
                                                 Converter={x:Static cvt:BoolToOpacityConverter.Instance}}"
                                       Padding="8,2" VerticalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                    <DataGridTemplateColumn.CellEditingTemplate>
                        <DataTemplate>
                            <TextBox Text="{Binding RangeMin, Mode=TwoWay}"
                                     HorizontalAlignment="Stretch"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellEditingTemplate>
                </DataGridTemplateColumn>

                <!-- Range Max — numeric types only -->
                <DataGridTemplateColumn Header="Range Max" Width="120">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding RangeMax, TargetNullValue='—'}"
                                       Opacity="{Binding IsNumericApplicable,
                                                 Converter={x:Static cvt:BoolToOpacityConverter.Instance}}"
                                       Padding="8,2" VerticalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                    <DataGridTemplateColumn.CellEditingTemplate>
                        <DataTemplate>
                            <TextBox Text="{Binding RangeMax, Mode=TwoWay}"
                                     HorizontalAlignment="Stretch"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellEditingTemplate>
                </DataGridTemplateColumn>

                <!-- Unit — numeric types only -->
                <DataGridTemplateColumn Header="Unit" Width="80">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Unit, TargetNullValue='—'}"
                                       Opacity="{Binding IsNumericApplicable,
                                                 Converter={x:Static cvt:BoolToOpacityConverter.Instance}}"
                                       Padding="8,2" VerticalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                    <DataGridTemplateColumn.CellEditingTemplate>
                        <DataTemplate>
                            <TextBox Text="{Binding Unit, Mode=TwoWay}"
                                     HorizontalAlignment="Stretch"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellEditingTemplate>
                </DataGridTemplateColumn>

                <!-- Calibration — numeric types only -->
                <DataGridTemplateColumn Header="Calibration" Width="*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding CalibrationFormula, TargetNullValue='—'}"
                                       Opacity="{Binding IsNumericApplicable,
                                                 Converter={x:Static cvt:BoolToOpacityConverter.Instance}}"
                                       Padding="8,2" VerticalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                    <DataGridTemplateColumn.CellEditingTemplate>
                        <DataTemplate>
                            <TextBox Text="{Binding CalibrationFormula, Mode=TwoWay}"
                                     HorizontalAlignment="Stretch"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellEditingTemplate>
                </DataGridTemplateColumn>

                <!-- Details — complex types summary, read-only -->
                <DataGridTemplateColumn Header="Details" Width="120" IsReadOnly="True">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Summary}"
                                       TextTrimming="CharacterEllipsis"
                                       Padding="8,2" VerticalAlignment="Center"
                                       ToolTip.Tip="{Binding Summary}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

            </DataGrid.Columns>
        </DataGrid>

    </DockPanel>
</Window>

