<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:IcdFyIt.App.ViewModels"
        xmlns:ctrl="using:IcdFyIt.App.Controls"
        x:Class="IcdFyIt.App.Views.DataTypesWindow"
        Icon="avares://IcdFyIt.App/Assets/icon.png"
        Title="Data Types"
        Width="1100" Height="640"
        MinWidth="700" MinHeight="400">

    <LayoutTransformControl>
        <LayoutTransformControl.LayoutTransform>
            <ScaleTransform ScaleX="{DynamicResource AppScale}" ScaleY="{DynamicResource AppScale}" />
        </LayoutTransformControl.LayoutTransform>
    <DockPanel>

        <!-- ── Toolbar: integrated menu + filter ──────────────────────────── -->
        <Border DockPanel.Dock="Top" Background="#2D2D30" Padding="0,1">
            <DockPanel LastChildFill="False">

                <!-- Left: action / column / data menus -->
                <Menu DockPanel.Dock="Left" Background="Transparent" VerticalAlignment="Center">

                    <!-- Edit actions -->
                    <MenuItem Header="Edit">
                        <MenuItem Header="Add…"      Command="{Binding AddCommand}"/>
                        <MenuItem Header="Duplicate" Command="{Binding DuplicateCommand}"/>
                        <MenuItem Header="Remove"    Command="{Binding RemoveCommand}"/>
                        <Separator IsVisible="{Binding CanEditValues}"/>
                        <MenuItem Header="Edit Values…" Command="{Binding EditValuesCommand}"
                                  IsVisible="{Binding CanEditValues}"/>
                        <Separator IsVisible="{Binding CanEditFields}"/>
                        <MenuItem Header="Edit Fields…" Command="{Binding EditStructureFieldsCommand}"
                                  IsVisible="{Binding CanEditFields}"/>
                        <Separator IsVisible="{Binding CanEditArray}"/>
                        <MenuItem Header="Edit Array…" Command="{Binding EditArrayCommand}"
                                  IsVisible="{Binding CanEditArray}"/>
                    </MenuItem>

                    <!-- Column visibility toggles -->
                    <MenuItem Header="Columns">
                        <MenuItem Header="Endianness"    x:Name="EndiannessItem"
                                  ToggleType="CheckBox" IsChecked="True"
                                  Click="OnColumnMenuItemChanged"/>
                        <MenuItem Header="Bit Size"      x:Name="BitSizeItem"
                                  ToggleType="CheckBox" IsChecked="True"
                                  Click="OnColumnMenuItemChanged"/>
                        <MenuItem Header="Range Min/Max" x:Name="RangeItem"
                                  ToggleType="CheckBox" IsChecked="True"
                                  Click="OnColumnMenuItemChanged"/>
                        <MenuItem Header="Unit"          x:Name="UnitItem"
                                  ToggleType="CheckBox" IsChecked="True"
                                  Click="OnColumnMenuItemChanged"/>
                        <MenuItem Header="Calibration"   x:Name="CalibrationItem"
                                  ToggleType="CheckBox" IsChecked="True"
                                  Click="OnColumnMenuItemChanged"/>
                        <MenuItem Header="Details"       x:Name="DetailsItem"
                                  ToggleType="CheckBox" IsChecked="True"
                                  Click="OnColumnMenuItemChanged"/>
                    </MenuItem>

                    <!-- CSV import / export -->
                    <MenuItem Header="Data">
                        <MenuItem Header="Export CSV" Command="{Binding ExportCsvCommand}"/>
                        <MenuItem Header="Import CSV" Command="{Binding ImportCsvCommand}"/>
                    </MenuItem>

                </Menu>

                <!-- Separator -->
                <Separator DockPanel.Dock="Left" Margin="4,4" Width="1" Background="#555"/>

                <!-- Filter by name -->
                <TextBlock DockPanel.Dock="Left" Text="Filter:" VerticalAlignment="Center"
                           Foreground="#CCCCCC" Margin="6,0,4,0"/>
                <TextBox   DockPanel.Dock="Left"
                           Text="{Binding FilterText, Mode=TwoWay}"
                           PlaceholderText="Search by name…"
                           Width="180" Margin="0,2,8,2" VerticalAlignment="Center"/>

                <!-- Filter by kind -->
                <TextBlock DockPanel.Dock="Left" Text="Kind:" VerticalAlignment="Center"
                           Foreground="#CCCCCC" Margin="0,0,4,0"/>
                <ComboBox  DockPanel.Dock="Left"
                           ItemsSource="{Binding AllKindFilters}"
                           SelectedItem="{Binding SelectedKindFilter, Mode=TwoWay}"
                           Width="140" VerticalAlignment="Center"/>

            </DockPanel>
        </Border>

        <!-- ── Spreadsheet grid (ICD-IF-120) ─────────────────────────────── -->
        <ctrl:DraggableGrid x:Name="TypesGrid"
                  ItemsSource="{Binding FilteredRows}"
                  SelectedItem="{Binding SelectedRow, Mode=TwoWay}">

            <!-- Context menu: Add / Duplicate / Remove + Edit Values for enums -->
            <ctrl:DraggableGrid.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Add…"         Command="{Binding AddCommand}"/>
                    <MenuItem Header="Duplicate"    Command="{Binding DuplicateCommand}"/>
                    <MenuItem Header="Remove"       Command="{Binding RemoveCommand}"/>
                    <Separator IsVisible="{Binding CanEditValues}"/>
                    <MenuItem Header="Edit Values…" Command="{Binding EditValuesCommand}"
                              IsVisible="{Binding CanEditValues}"/>
                    <Separator IsVisible="{Binding CanEditFields}"/>
                    <MenuItem Header="Edit Fields…" Command="{Binding EditStructureFieldsCommand}"
                              IsVisible="{Binding CanEditFields}"/>
                    <Separator IsVisible="{Binding CanEditArray}"/>
                    <MenuItem Header="Edit Array…" Command="{Binding EditArrayCommand}"
                              IsVisible="{Binding CanEditArray}"/>
                </ContextMenu>
            </ctrl:DraggableGrid.ContextMenu>

            <ctrl:DraggableGrid.Columns>

                <!-- Drag handle -->
                <ctrl:DraggableGridColumn ColumnType="DragHandle" Width="24"/>

                <!-- Name — all types -->
                <ctrl:DraggableGridColumn Header="Name"
                                          Path="Name"
                                          Width="160"
                                          IsEditable="True"/>

                <!-- Kind — all types, read-only -->
                <ctrl:DraggableGridColumn Header="Kind"
                                          Path="Kind"
                                          Width="130"/>

                <!-- Endianness — RadioButtons built in code-behind (no popup, safe on X11) -->
                <ctrl:DraggableGridColumn Header="Endianness"
                                          Name="Endianness"
                                          Width="115"/>

                <!-- Bit Size — scalar types and Enumerated -->
                <ctrl:DraggableGridColumn Header="Bit Size"
                                          Path="BitSize"
                                          NullText="—"
                                          Width="95"
                                          IsEditable="True"
                                          IsEnabledPath="IsBitSizeApplicable"
                                          OpacityPath="IsBitSizeApplicable"
                                          Name="BitSize"/>

                <!-- Range Min — numeric types only -->
                <ctrl:DraggableGridColumn Header="Range Min"
                                          Path="RangeMin"
                                          NullText="—"
                                          Width="120"
                                          IsEditable="True"
                                          IsEnabledPath="IsNumericApplicable"
                                          OpacityPath="IsNumericApplicable"
                                          Name="RangeMin"/>

                <!-- Range Max — numeric types only -->
                <ctrl:DraggableGridColumn Header="Range Max"
                                          Path="RangeMax"
                                          NullText="—"
                                          Width="120"
                                          IsEditable="True"
                                          IsEnabledPath="IsNumericApplicable"
                                          OpacityPath="IsNumericApplicable"
                                          Name="RangeMax"/>

                <!-- Unit — numeric types only -->
                <ctrl:DraggableGridColumn Header="Unit"
                                          Path="Unit"
                                          NullText="—"
                                          Width="80"
                                          IsEditable="True"
                                          IsEnabledPath="IsNumericApplicable"
                                          OpacityPath="IsNumericApplicable"
                                          Name="Unit"/>

                <!-- Calibration — numeric types only -->
                <ctrl:DraggableGridColumn Header="Calibration"
                                          Path="CalibrationFormula"
                                          NullText="—"
                                          Width="150"
                                          IsEditable="True"
                                          IsEnabledPath="IsNumericApplicable"
                                          OpacityPath="IsNumericApplicable"
                                          Name="Calibration"/>

                <!-- Details — complex types summary; CellFactory (tooltip + trimming) in code-behind -->
                <ctrl:DraggableGridColumn Header="Details"
                                          Width="120"
                                          Name="Details"/>

            </ctrl:DraggableGrid.Columns>
        </ctrl:DraggableGrid>

    </DockPanel>
    </LayoutTransformControl>
</Window>

