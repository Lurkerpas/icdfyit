<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:IcdFyIt.App.ViewModels"
        xmlns:cvt="using:IcdFyIt.App.Converters"
        xmlns:ctrl="using:IcdFyIt.App.Controls"
        x:Class="IcdFyIt.App.Views.ParametersWindow"
        Icon="avares://IcdFyIt.App/Assets/icon.png"
        Title="Parameters"
        Width="1100" Height="640"
        MinWidth="700" MinHeight="400">

    <LayoutTransformControl>
        <LayoutTransformControl.LayoutTransform>
            <ScaleTransform ScaleX="{DynamicResource AppScale}" ScaleY="{DynamicResource AppScale}" />
        </LayoutTransformControl.LayoutTransform>
    <DockPanel>

        <!-- ── Toolbar: integrated menu + filter ──────────────────────────── -->
        <Border DockPanel.Dock="Top" Background="#2D2D30" Padding="0,1">
            <DockPanel LastChildFill="False">

                <!-- Left: action / column / data menus -->
                <Menu DockPanel.Dock="Left" Background="Transparent" VerticalAlignment="Center">

                    <!-- Edit actions -->
                    <MenuItem Header="Edit">
                        <MenuItem Header="Add…"      Command="{Binding AddCommand}"/>
                        <MenuItem Header="Duplicate" Command="{Binding DuplicateCommand}"/>
                        <MenuItem Header="Remove"    Command="{Binding RemoveCommand}"/>
                        <Separator/>
                        <MenuItem Header="Edit Attributes…" Command="{Binding EditAttributesCommand}"/>
                    </MenuItem>

                    <!-- Column visibility toggles (ICD-IF-150) -->
                    <MenuItem Header="Columns">
                        <MenuItem Header="Mnemonic"          x:Name="MnemonicItem"
                                  ToggleType="CheckBox" IsChecked="True"
                                  Click="OnColumnMenuItemChanged"/>
                        <MenuItem Header="Kind"              x:Name="KindItem"
                                  ToggleType="CheckBox" IsChecked="True"
                                  Click="OnColumnMenuItemChanged"/>
                        <MenuItem Header="Numeric ID"        x:Name="NumericIdItem"
                                  ToggleType="CheckBox" IsChecked="True"
                                  Click="OnColumnMenuItemChanged"/>
                        <MenuItem Header="Short Description" x:Name="ShortDescItem"
                                  ToggleType="CheckBox" IsChecked="True"
                                  Click="OnColumnMenuItemChanged"/>
                        <MenuItem Header="Long Description"  x:Name="LongDescItem"
                                  ToggleType="CheckBox" IsChecked="True"
                                  Click="OnColumnMenuItemChanged"/>
                        <MenuItem Header="Data Type"         x:Name="DataTypeItem"
                                  ToggleType="CheckBox" IsChecked="True"
                                  Click="OnColumnMenuItemChanged"/>
                        <MenuItem Header="Formula"           x:Name="FormulaItem"
                                  ToggleType="CheckBox" IsChecked="True"
                                  Click="OnColumnMenuItemChanged"/>
                        <MenuItem Header="Hex Value"         x:Name="HexValueItem"
                                  ToggleType="CheckBox" IsChecked="True"
                                  Click="OnColumnMenuItemChanged"/>
                        <MenuItem Header="Memory"            x:Name="MemoryItem"
                                  ToggleType="CheckBox" IsChecked="True"
                                  Click="OnColumnMenuItemChanged"/>
                        <MenuItem Header="Memory Offset"     x:Name="MemoryOffsetItem"
                                  ToggleType="CheckBox" IsChecked="True"
                                  Click="OnColumnMenuItemChanged"/>
                        <MenuItem Header="Validity Parameter" x:Name="ValidityParamItem"
                                  ToggleType="CheckBox" IsChecked="True"
                                  Click="OnColumnMenuItemChanged"/>
                        <MenuItem Header="Alarm Low"         x:Name="AlarmLowItem"
                                  ToggleType="CheckBox" IsChecked="True"
                                  Click="OnColumnMenuItemChanged"/>
                        <MenuItem Header="Alarm High"        x:Name="AlarmHighItem"
                                  ToggleType="CheckBox" IsChecked="True"
                                  Click="OnColumnMenuItemChanged"/>
                    </MenuItem>

                    <!-- CSV import / export -->
                    <MenuItem Header="Data">
                        <MenuItem Header="Export CSV" Command="{Binding ExportCsvCommand}"/>
                        <MenuItem Header="Import CSV" Command="{Binding ImportCsvCommand}"/>
                    </MenuItem>

                </Menu>

                <!-- Separator -->
                <Separator DockPanel.Dock="Left" Margin="4,4" Width="1" Background="#555"/>

                <!-- Filter by name / mnemonic -->
                <TextBlock DockPanel.Dock="Left" Text="Filter:" VerticalAlignment="Center"
                           Foreground="#CCCCCC" Margin="6,0,4,0"/>
                <TextBox   DockPanel.Dock="Left"
                           Text="{Binding FilterText, Mode=TwoWay}"
                           PlaceholderText="Search name or mnemonic…"
                           Width="200" Margin="0,2,8,2" VerticalAlignment="Center"/>

                <!-- Filter by kind -->
                <TextBlock DockPanel.Dock="Left" Text="Kind:" VerticalAlignment="Center"
                           Foreground="#CCCCCC" Margin="0,0,4,0"/>
                <ComboBox  DockPanel.Dock="Left"
                           ItemsSource="{Binding AllKindFilters}"
                           SelectedItem="{Binding SelectedKindFilter, Mode=TwoWay}"
                           Width="160" VerticalAlignment="Center"/>

            </DockPanel>
        </Border>

        <!-- ── Spreadsheet grid with native drag-to-reorder (ICD-IF-92) ─────── -->
        <ctrl:DraggableGrid x:Name="ParamsGrid"
                            ItemsSource="{Binding FilteredRows}"
                            SelectedItem="{Binding SelectedRow, Mode=TwoWay}">

            <ctrl:DraggableGrid.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Add…"               Command="{Binding AddCommand}"/>
                    <MenuItem Header="Duplicate"          Command="{Binding DuplicateCommand}"/>
                    <MenuItem Header="Remove"             Command="{Binding RemoveCommand}"/>
                    <Separator/>
                    <MenuItem Header="Edit Attributes…"  Command="{Binding EditAttributesCommand}"/>
                </ContextMenu>
            </ctrl:DraggableGrid.ContextMenu>

            <ctrl:DraggableGrid.Columns>

                <!-- Drag handle — press and drag to reorder rows -->
                <ctrl:DraggableGridColumn ColumnType="DragHandle" Width="24"/>

                <!-- Name — all parameters -->
                <ctrl:DraggableGridColumn Header="Name"
                                          Path="Name"
                                          Width="150"
                                          IsEditable="True"/>

                <!-- Mnemonic -->
                <ctrl:DraggableGridColumn Header="Mnemonic"
                                          Path="Mnemonic"
                                          Width="110"
                                          IsEditable="True"
                                          Name="Mnemonic"/>

                <!-- Kind — read-only; edited via dialog -->
                <ctrl:DraggableGridColumn Header="Kind"
                                          Path="Kind"
                                          Width="130"
                                          Name="Kind"/>

                <!-- Numeric ID -->
                <ctrl:DraggableGridColumn Header="Numeric ID"
                                          Path="NumericId"
                                          Width="85"
                                          IsEditable="True"
                                          Name="NumericId"/>

                <!-- Data Type — read-only; edited via dialog -->
                <ctrl:DraggableGridColumn Header="Data Type"
                                          Path="DataTypeName"
                                          Width="130"
                                          Name="DataType"/>

                <!-- Short Description -->
                <ctrl:DraggableGridColumn Header="Short Description"
                                          Path="ShortDescription"
                                          Width="180"
                                          IsEditable="True"
                                          Name="ShortDescription"/>

                <!-- Formula — only applicable for SyntheticValue kind -->
                <ctrl:DraggableGridColumn Header="Formula"
                                          Path="Formula"
                                          Width="140"
                                          IsEditable="True"
                                          IsEnabledPath="IsFormulaApplicable"
                                          Name="Formula"/>

                <!-- Hex Value — only applicable for FixedValue kind -->
                <ctrl:DraggableGridColumn Header="Hex Value"
                                          Path="HexValue"
                                          Width="100"
                                          IsEditable="True"
                                          IsEnabledPath="IsHexValueApplicable"
                                          Name="HexValue"/>

                <!-- Long Description -->
                <ctrl:DraggableGridColumn Header="Long Description"
                                          Path="LongDescription"
                                          Width="180"
                                          IsEditable="True"
                                          Name="LongDescription"/>

                <!-- Memory (read-only; set via dialog) -->
                <ctrl:DraggableGridColumn Header="Memory"
                                          Path="MemoryName"
                                          Width="120"
                                          Name="Memory"/>

                <!-- Memory Offset -->
                <ctrl:DraggableGridColumn Header="Offset"
                                          Path="MemoryOffset"
                                          Width="70"
                                          IsEditable="True"
                                          IsEnabledPath="HasMemory"
                                          Name="MemoryOffset"/>

                <!-- Validity Parameter (read-only; set via dialog) -->
                <ctrl:DraggableGridColumn Header="Validity Parameter"
                                          Path="ValidityParameterName"
                                          Width="140"
                                          Name="ValidityParam"/>

                <!-- Alarm Low -->
                <ctrl:DraggableGridColumn Header="Alarm Low"
                                          Path="AlarmLow"
                                          Width="90"
                                          IsEditable="True"
                                          IsEnabledPath="IsNumericApplicable"
                                          Name="AlarmLow"/>

                <!-- Alarm High -->
                <ctrl:DraggableGridColumn Header="Alarm High"
                                          Path="AlarmHigh"
                                          Width="90"
                                          IsEditable="True"
                                          IsEnabledPath="IsNumericApplicable"
                                          Name="AlarmHigh"/>

            </ctrl:DraggableGrid.Columns>
        </ctrl:DraggableGrid>

    </DockPanel>
    </LayoutTransformControl>
</Window>

