<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:IcdFyIt.App.ViewModels"
        xmlns:cvt="using:IcdFyIt.App.Converters"
        x:Class="IcdFyIt.App.Views.ParametersWindow"
        Title="Parameters"
        Width="1100" Height="640"
        MinWidth="700" MinHeight="400">

    <LayoutTransformControl>
        <LayoutTransformControl.LayoutTransform>
            <ScaleTransform ScaleX="{DynamicResource AppScale}" ScaleY="{DynamicResource AppScale}" />
        </LayoutTransformControl.LayoutTransform>
    <DockPanel>

        <!-- ── Toolbar: integrated menu + filter ──────────────────────────── -->
        <Border DockPanel.Dock="Top" Background="#2D2D30" Padding="0,1">
            <DockPanel LastChildFill="False">

                <!-- Left: action / column / data menus -->
                <Menu DockPanel.Dock="Left" Background="Transparent" VerticalAlignment="Center">

                    <!-- Edit actions -->
                    <MenuItem Header="Edit">
                        <MenuItem Header="Add…"      Command="{Binding AddCommand}"/>
                        <MenuItem Header="Duplicate" Command="{Binding DuplicateCommand}"/>
                        <MenuItem Header="Remove"    Command="{Binding RemoveCommand}"/>
                        <Separator/>
                        <MenuItem Header="Edit Attributes…" Command="{Binding EditAttributesCommand}"/>
                    </MenuItem>

                    <!-- Column visibility toggles (ICD-IF-150) -->
                    <MenuItem Header="Columns">
                        <MenuItem Header="Mnemonic"          x:Name="MnemonicItem"
                                  ToggleType="CheckBox" IsChecked="True"
                                  Click="OnColumnMenuItemChanged"/>
                        <MenuItem Header="Kind"              x:Name="KindItem"
                                  ToggleType="CheckBox" IsChecked="True"
                                  Click="OnColumnMenuItemChanged"/>
                        <MenuItem Header="Numeric ID"        x:Name="NumericIdItem"
                                  ToggleType="CheckBox" IsChecked="True"
                                  Click="OnColumnMenuItemChanged"/>
                        <MenuItem Header="Short Description" x:Name="ShortDescItem"
                                  ToggleType="CheckBox" IsChecked="True"
                                  Click="OnColumnMenuItemChanged"/>
                        <MenuItem Header="Long Description"  x:Name="LongDescItem"
                                  ToggleType="CheckBox" IsChecked="True"
                                  Click="OnColumnMenuItemChanged"/>
                        <MenuItem Header="Data Type"         x:Name="DataTypeItem"
                                  ToggleType="CheckBox" IsChecked="True"
                                  Click="OnColumnMenuItemChanged"/>
                        <MenuItem Header="Formula"           x:Name="FormulaItem"
                                  ToggleType="CheckBox" IsChecked="True"
                                  Click="OnColumnMenuItemChanged"/>
                        <MenuItem Header="Hex Value"         x:Name="HexValueItem"
                                  ToggleType="CheckBox" IsChecked="True"
                                  Click="OnColumnMenuItemChanged"/>
                    </MenuItem>

                    <!-- CSV import / export -->
                    <MenuItem Header="Data">
                        <MenuItem Header="Export CSV" Command="{Binding ExportCsvCommand}"/>
                        <MenuItem Header="Import CSV" Command="{Binding ImportCsvCommand}"/>
                    </MenuItem>

                </Menu>

                <!-- Separator -->
                <Separator DockPanel.Dock="Left" Margin="4,4" Width="1" Background="#555"/>

                <!-- Filter by name / mnemonic -->
                <TextBlock DockPanel.Dock="Left" Text="Filter:" VerticalAlignment="Center"
                           Foreground="#CCCCCC" Margin="6,0,4,0"/>
                <TextBox   DockPanel.Dock="Left"
                           Text="{Binding FilterText, Mode=TwoWay}"
                           PlaceholderText="Search name or mnemonic…"
                           Width="200" Margin="0,2,8,2" VerticalAlignment="Center"/>

                <!-- Filter by kind -->
                <TextBlock DockPanel.Dock="Left" Text="Kind:" VerticalAlignment="Center"
                           Foreground="#CCCCCC" Margin="0,0,4,0"/>
                <ComboBox  DockPanel.Dock="Left"
                           ItemsSource="{Binding AllKindFilters}"
                           SelectedItem="{Binding SelectedKindFilter, Mode=TwoWay}"
                           Width="160" VerticalAlignment="Center"/>

            </DockPanel>
        </Border>

        <!-- ── Spreadsheet grid (ICD-IF-92) ──────────────────────────────── -->
        <DataGrid x:Name="ParamsGrid"
                  ItemsSource="{Binding FilteredRows}"
                  SelectedItem="{Binding SelectedRow, Mode=TwoWay}"
                  AutoGenerateColumns="False"
                  CanUserSortColumns="True"
                  CanUserResizeColumns="True"
                  IsReadOnly="False"
                  CellEditEnded="OnCellEditEnded"
                  BeginningEdit="OnBeginningEdit">

            <!-- Context menu -->
            <DataGrid.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Add…"         Command="{Binding AddCommand}"/>
                    <MenuItem Header="Duplicate"    Command="{Binding DuplicateCommand}"/>
                    <MenuItem Header="Remove"       Command="{Binding RemoveCommand}"/>
                    <Separator/>
                    <MenuItem Header="Edit Attributes…" Command="{Binding EditAttributesCommand}"/>
                </ContextMenu>
            </DataGrid.ContextMenu>

            <DataGrid.Columns>

                <!-- Drag handle — click and drag to reorder rows -->
                <DataGridTemplateColumn Header="" Width="24"
                                        IsReadOnly="True" CanUserSort="False">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="☰"
                                       Classes="drag-handle"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Cursor="SizeNorthSouth"
                                       ToolTip.Tip="Drag to reorder"
                                       Foreground="#888"
                                       FontSize="13"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Name — all parameters -->
                <DataGridTextColumn Header="Name"
                                    Binding="{Binding Name, Mode=TwoWay}"
                                    Width="150"/>

                <!-- Mnemonic -->
                <DataGridTextColumn Header="Mnemonic"
                                    Binding="{Binding Mnemonic, Mode=TwoWay}"
                                    Width="110"/>

                <!-- Kind — read-only; edited via dialog -->
                <DataGridTextColumn Header="Kind"
                                    Binding="{Binding Kind}"
                                    Width="130" IsReadOnly="True"/>

                <!-- Numeric ID -->
                <DataGridTemplateColumn Header="Numeric ID" Width="85">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding NumericId}"
                                       Padding="8,2" VerticalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                    <DataGridTemplateColumn.CellEditingTemplate>
                        <DataTemplate>
                            <TextBox Text="{Binding NumericId, Mode=TwoWay}"
                                     HorizontalAlignment="Stretch"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellEditingTemplate>
                </DataGridTemplateColumn>

                <!-- Data Type — read-only; edited via dialog -->
                <DataGridTextColumn Header="Data Type"
                                    Binding="{Binding DataTypeName}"
                                    Width="130" IsReadOnly="True"/>

                <!-- Short Description -->
                <DataGridTextColumn Header="Short Description"
                                    Binding="{Binding ShortDescription, Mode=TwoWay}"
                                    Width="180"/>

                <!-- Formula — SyntheticValue kind only -->
                <DataGridTemplateColumn Header="Formula" Width="140">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding FormulaDisplay, TargetNullValue='-'}"
                                       Padding="8,2" VerticalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                    <DataGridTemplateColumn.CellEditingTemplate>
                        <DataTemplate>
                            <TextBox Text="{Binding Formula, Mode=TwoWay}"
                                     HorizontalAlignment="Stretch"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellEditingTemplate>
                </DataGridTemplateColumn>

                <!-- Hex Value — FixedValue kind only -->
                <DataGridTemplateColumn Header="Hex Value" Width="100">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding HexValue, TargetNullValue='-'}"
                                       Opacity="{Binding IsHexValueApplicable,
                                                 Converter={x:Static cvt:BoolToOpacityConverter.Instance}}"
                                       Padding="8,2" VerticalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                    <DataGridTemplateColumn.CellEditingTemplate>
                        <DataTemplate>
                            <TextBox Text="{Binding HexValue, Mode=TwoWay}"
                                     HorizontalAlignment="Stretch"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellEditingTemplate>
                </DataGridTemplateColumn>

                <!-- Long Description -->
                <DataGridTextColumn Header="Long Description"
                                    Binding="{Binding LongDescription, Mode=TwoWay}"
                                    Width="180"/>

            </DataGrid.Columns>
        </DataGrid>

    </DockPanel>
    </LayoutTransformControl>
</Window>

