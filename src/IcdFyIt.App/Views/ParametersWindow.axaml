<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:IcdFyIt.App.ViewModels"
        x:Class="IcdFyIt.App.Views.ParametersWindow"
        Title="Parameters"
        Width="1000" Height="600"
        MinWidth="700" MinHeight="400">

    <DockPanel>
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Spacing="4" Margin="4">
            <Button Content="Add"       Command="{Binding AddCommand}" />
            <Button Content="Duplicate" Command="{Binding DuplicateCommand}" />
            <Button Content="Remove"    Command="{Binding RemoveCommand}" />
        </StackPanel>

        <DataGrid ItemsSource="{Binding Parameters}"
                  SelectedItem="{Binding Selected}"
                  AutoGenerateColumns="False"
                  CanUserSortColumns="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Name"       Binding="{Binding Name}"      Width="*" />
                <DataGridTextColumn Header="Mnemonic"   Binding="{Binding Mnemonic}"  Width="120" />
                <DataGridTextColumn Header="Kind"       Binding="{Binding Kind}"      Width="160" />
                <DataGridTextColumn Header="Numeric ID" Binding="{Binding NumericId}" Width="90" />
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>
