<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="IcdFyIt.GuiReporter.ReporterApp"
             RequestedThemeVariant="Dark">

    <Application.Resources>
        <ResourceDictionary>
            <!-- Mirrors IcdFyIt.App/App.axaml — updated at runtime per captured scale -->
            <x:Double x:Key="AppScale">1</x:Double>
            <x:Double x:Key="AppMenuFontSize">14</x:Double>

            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Dark">
                    <Color x:Key="SystemAltHighColor">#1E1E1E</Color>
                    <Color x:Key="SystemAltMediumHighColor">#CC1E1E1E</Color>
                    <Color x:Key="SystemAltMediumColor">#991E1E1E</Color>
                    <Color x:Key="SystemAltMediumLowColor">#661E1E1E</Color>
                    <Color x:Key="SystemAltLowColor">#331E1E1E</Color>
                    <Color x:Key="SystemChromeLowColor">#1E1E1E</Color>
                    <Color x:Key="SystemChromeMediumLowColor">#252526</Color>
                    <Color x:Key="SystemChromeMediumColor">#2D2D30</Color>
                    <Color x:Key="SystemChromeHighColor">#3E3E42</Color>
                    <Color x:Key="SystemAccentColor">#007ACC</Color>
                    <Color x:Key="SystemBaseMediumHighColor">#CCCCCC</Color>
                    <Color x:Key="SystemBaseMediumColor">#A0A0A0</Color>
                    <Color x:Key="SystemBaseMediumLowColor">#858585</Color>
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
        </ResourceDictionary>
    </Application.Resources>

    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="avares://Avalonia.Controls.DataGrid/Themes/Fluent.xaml"/>
        <Styles>
            <Style Selector="Window">
                <Setter Property="Background" Value="#1E1E1E"/>
            </Style>
            <Style Selector="Menu">
                <Setter Property="Background" Value="#2D2D30"/>
            </Style>
            <Style Selector="TabControl">
                <Setter Property="Background" Value="#252526"/>
            </Style>
        </Styles>
    </Application.Styles>
</Application>
